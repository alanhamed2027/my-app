# Environment Variables

# Node.js server port
PORT=5000
NODE_ENV=development

# MySQL Database connection string for Prisma
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Default XAMPP MySQL has username 'root' and empty password
DATABASE_URL="mysql://root:@localhost:3306/it_asset_management"

# JWT Secret Key for Authentication (Change this in production)
JWT_SECRET="super-secret-government-key-2026"
JWT_EXPIRES_IN="1d"

# Frontend URL (for CORS)
CLIENT_URL="http://localhost:5173"
